---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimatedEntry from '../components/AnimatedEntry.jsx';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<BaseLayout title="Projects — r.s">
  <section
    style={{
      maxWidth: "800px",
      margin: "0 auto",
      padding: "80px 32px",
    }}
  >
    <AnimatedEntry client:load>
      <h1
        style={{
          fontFamily: "'Cormorant Garamond', Georgia, serif",
          fontSize: "48px",
          fontWeight: 400,
          marginBottom: "16px",
        }}
      >
        Projects
      </h1>
      <p
        style={{
          fontSize: "16px",
          color: "#7A6F64",
          fontWeight: 300,
          lineHeight: 1.7,
          marginBottom: "60px",
          maxWidth: "500px",
        }}
      >
        Things I'm building, breaking, and learning from. Some are polished,
        most are experiments.
      </p>
    </AnimatedEntry>

    {projects.map((proj, i) => (
      <AnimatedEntry client:visible delay={i * 120}>
        <div
          style={{
            background: "#FFFFFF",
            border: "1px solid #E5DDD3",
            borderRadius: "12px",
            padding: "36px",
            marginBottom: "20px",
          }}
        >
          <div
            style={{
              display: "flex",
              justifyContent: "space-between",
              alignItems: "flex-start",
              marginBottom: "12px",
              flexWrap: "wrap",
              gap: "8px",
            }}
          >
            <h2
              style={{
                fontFamily: "'Cormorant Garamond', Georgia, serif",
                fontSize: "26px",
                fontWeight: 600,
              }}
            >
              {proj.data.name}
            </h2>
            <span
              style={{
                fontSize: "11px",
                textTransform: "uppercase",
                letterSpacing: "1.5px",
                color:
                  proj.data.status === "Active"
                    ? "#4A8C5E"
                    : proj.data.status === "In Progress"
                    ? "#C0754A"
                    : "#7A6F64",
                fontWeight: 600,
                background:
                  proj.data.status === "Active"
                    ? "#D4E4DB"
                    : proj.data.status === "In Progress"
                    ? "#E8CDB5"
                    : "#F2EDE5",
                padding: "4px 12px",
                borderRadius: "20px",
              }}
            >
              {proj.data.status}
            </span>
          </div>
          <p
            style={{
              fontSize: "15px",
              color: "#7A6F64",
              lineHeight: 1.7,
              fontWeight: 300,
              marginBottom: "16px",
            }}
          >
            {proj.data.description}
          </p>
          <span
            style={{
              fontSize: "12px",
              color: "#C0754A",
              fontWeight: 500,
              fontFamily: "'DM Sans', sans-serif",
            }}
          >
            {proj.data.tech}
          </span>
        </div>
      </AnimatedEntry>
    ))}
  </section>
</BaseLayout>
