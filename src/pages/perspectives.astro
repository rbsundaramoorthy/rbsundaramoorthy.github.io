---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimatedEntry from '../components/AnimatedEntry.jsx';
---

<BaseLayout title="Perspectives — r.s">
  <section
    style={{
      maxWidth: "800px",
      margin: "0 auto",
      padding: "80px 32px",
    }}
  >
    <AnimatedEntry client:load>
      <h1
        style={{
          fontFamily: "'Cormorant Garamond', Georgia, serif",
          fontSize: "48px",
          fontWeight: 400,
          marginBottom: "16px",
        }}
      >
        Perspectives
      </h1>
      <p
        style={{
          fontSize: "16px",
          color: "#7A6F64",
          fontWeight: 300,
          lineHeight: 1.7,
          marginBottom: "60px",
          maxWidth: "540px",
        }}
      >
        A space for different angles. Your take might be nothing like mine —
        and that's exactly the point. Share a thought, challenge an idea, or
        just say hello.
      </p>
    </AnimatedEntry>

    <AnimatedEntry client:visible delay={150}>
      <div
        style={{
          background: "#FFFFFF",
          border: "1px solid #E5DDD3",
          borderRadius: "12px",
          padding: "40px",
          marginBottom: "40px",
        }}
      >
        <h3
          style={{
            fontFamily: "'Cormorant Garamond', Georgia, serif",
            fontSize: "24px",
            fontWeight: 600,
            marginBottom: "24px",
          }}
        >
          This month's question
        </h3>
        <iframe
          data-tally-src="https://tally.so/embed/q4PGKG?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
          loading="lazy"
          width="100%"
          height="300"
          frameborder="0"
          title="Monthly question"
          style={{ border: "none" }}
        ></iframe>
        <button
          data-tally-open="q4PGKG"
          data-tally-emoji-text="👋"
          data-tally-emoji-animation="wave"
          style={{
            padding: "14px 32px",
            background: "#C0754A",
            color: "#FAF7F2",
            border: "none",
            borderRadius: "8px",
            fontFamily: "'DM Sans', sans-serif",
            fontSize: "15px",
            fontWeight: 500,
            cursor: "pointer",
            transition: "all 0.3s ease",
            marginTop: "20px",
          }}
        >
          Share your answer
        </button>
      </div>
    </AnimatedEntry>

    <AnimatedEntry client:visible delay={300}>
      <div
        style={{
          background: "#FFFFFF",
          border: "1px solid #E5DDD3",
          borderRadius: "12px",
          padding: "40px",
        }}
      >
        <h3
          style={{
            fontFamily: "'Cormorant Garamond', Georgia, serif",
            fontSize: "24px",
            fontWeight: 600,
            marginBottom: "24px",
          }}
        >
          Quick poll
        </h3>
        <p
          style={{
            fontSize: "15px",
            color: "#7A6F64",
            lineHeight: 1.7,
            fontWeight: 300,
            marginBottom: "20px",
          }}
        >
          Light-hearted polls, rotating weekly. No logins, no fuss.
        </p>
        <iframe
          data-tally-src="https://tally.so/embed/OD0X0g?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
          loading="lazy"
          width="100%"
          height="300"
          frameborder="0"
          title="Quick poll"
          style={{ border: "none" }}
        ></iframe>
        <button
          data-tally-open="OD0X0g"
          data-tally-emoji-text="👋"
          data-tally-emoji-animation="wave"
          style={{
            padding: "14px 32px",
            background: "#C0754A",
            color: "#FAF7F2",
            border: "none",
            borderRadius: "8px",
            fontFamily: "'DM Sans', sans-serif",
            fontSize: "15px",
            fontWeight: 500,
            cursor: "pointer",
            transition: "all 0.3s ease",
            marginTop: "20px",
          }}
        >
          Share your answer
        </button>
      </div>
    </AnimatedEntry>
  </section>
</BaseLayout>
